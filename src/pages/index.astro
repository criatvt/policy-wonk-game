---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Policy Wonk" zone="game">
  <section class="text-center py-16 md:py-24 flex flex-col items-center gap-8">
    <p class="text-sm uppercase tracking-widest opacity-70">A quiz on Indian public policy</p>
    <h1 class="text-5xl md:text-7xl font-semibold leading-tight">Policy Wonk</h1>
    <p class="text-lg max-w-xl opacity-90">
      Fifteen questions. Four difficulty tiers. Three lifelines. Two safety nets.
      One crore credibility points if you go all the way.
    </p>
    <a
      href="/play"
      class="px-8 py-4 rounded bg-[var(--color-charcoal)] text-[var(--color-bg)] text-lg font-semibold hover:opacity-90 transition-opacity"
    >
      Play
    </a>
    <p class="text-xs opacity-60 max-w-md">
      Built on Takshashila GCPP course material. Most fun if you've taken the courses;
      welcoming if you haven't.
    </p>
  </section>
</BaseLayout>
