---
import BaseLayout from "../layouts/BaseLayout.astro";

const errorParam = Astro.url.searchParams.get("error");
const errorMessages: Record<string, string> = {
  missing_token: "The sign-in link was incomplete. Try again.",
  invalid_or_expired: "That sign-in link has expired or already been used. Send yourself a fresh one.",
  server: "Something went wrong on our end. Try again in a moment.",
};
const errorMessage = errorParam ? (errorMessages[errorParam] ?? "Sign-in failed. Try again.") : null;
---
<BaseLayout title="Sign in · Policy Wonk" description="Sign in to Policy Wonk with a one-time link sent to your email.">
  <section class="max-w-md mx-auto py-12">
    <header class="mb-8">
      <p class="text-xs uppercase tracking-widest text-gray-500 mb-2">Policy Wonk</p>
      <h1 class="font-serif text-3xl md:text-4xl font-bold leading-tight">Sign in</h1>
      <p class="mt-3 text-gray-700 leading-relaxed">Enter your email. We'll send you a one-time link that signs you in — no password.</p>
    </header>

    {errorMessage && (
      <div role="alert" class="mb-6 p-4 border-l-4 border-red-600 bg-red-50 text-red-900 text-sm">
        {errorMessage}
      </div>
    )}

    <form id="login-form" class="space-y-4" novalidate>
      <div>
        <label for="email" class="block text-sm font-medium mb-2">Email</label>
        <input
          type="email"
          id="email"
          name="email"
          required
          autocomplete="email"
          spellcheck="false"
          class="w-full px-4 py-3 border border-gray-400 bg-white focus:outline-none focus:border-black"
          placeholder="you@example.com"
        />
      </div>
      <button
        type="submit"
        id="submit-btn"
        class="w-full px-6 py-3 bg-black text-white font-semibold hover:bg-gray-800 disabled:opacity-50 disabled:cursor-wait"
      >
        Send me a sign-in link
      </button>
    </form>

    <div id="login-success" class="hidden mt-6 p-5 border-l-4 border-green-700 bg-green-50">
      <p class="font-semibold text-green-900">Check your email</p>
      <p class="mt-1 text-sm text-green-900">If that address is on file, a sign-in link is on its way. It expires in 10 minutes.</p>
    </div>

    <div id="login-error" class="hidden mt-6 p-5 border-l-4 border-red-600 bg-red-50">
      <p class="text-sm text-red-900" id="login-error-text"></p>
    </div>

    <div class="mt-12 pt-6 border-t border-gray-300">
      <p class="text-sm text-gray-700 mb-2">Don't want to sign in?</p>
      <a href="/play" class="text-sm font-medium underline">Play as guest →</a>
      <p class="mt-3 text-xs text-gray-500 leading-relaxed">We store your email, nickname, avatar, and play history. We don't track you and don't share with third parties.</p>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById("login-form") as HTMLFormElement;
  const emailInput = document.getElementById("email") as HTMLInputElement;
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
  const successEl = document.getElementById("login-success") as HTMLDivElement;
  const errorEl = document.getElementById("login-error") as HTMLDivElement;
  const errorText = document.getElementById("login-error-text") as HTMLParagraphElement;

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    successEl.classList.add("hidden");
    errorEl.classList.add("hidden");

    const email = emailInput.value.trim();
    if (!email) return;

    submitBtn.disabled = true;
    submitBtn.textContent = "Sending…";

    try {
      const res = await fetch("/api/auth/send-link", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ email }),
      });

      if (res.ok) {
        successEl.classList.remove("hidden");
        form.classList.add("hidden");
      } else {
        const data = (await res.json().catch(() => ({}))) as { error?: string };
        errorText.textContent =
          data.error === "invalid_email"
            ? "That doesn't look like a valid email. Double-check and try again."
            : "Something went wrong sending the link. Try again in a moment.";
        errorEl.classList.remove("hidden");
        submitBtn.disabled = false;
        submitBtn.textContent = "Send me a sign-in link";
      }
    } catch {
      errorText.textContent = "Couldn't reach the server. Check your connection and try again.";
      errorEl.classList.remove("hidden");
      submitBtn.disabled = false;
      submitBtn.textContent = "Send me a sign-in link";
    }
  });
</script>
