---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SearchBar from "../../components/shared/SearchBar.astro";
import { getCollection } from "astro:content";
import modulesData from "../../data/modules.json";

type Module = (typeof modulesData)[number];

// Determine which modules have at least one note file shipped.
// All 11 modules now have notes coverage (v0.3.4); a module is treated
// as "available" iff it has at least one entry in the content collection.
const allNotes = await getCollection("notes");
const modulesWithNotes = new Set(allNotes.map((n) => n.data.module));

const groupOrder = ["Foundations", "Economic Reasoning", "Strategy & Society"];
const grouped: Record<string, Module[]> = {};
for (const m of modulesData as Module[]) {
  if (!grouped[m.group]) grouped[m.group] = [];
  grouped[m.group].push(m);
}
---
<BaseLayout title="Notes · Policy Wonk" description="Revision notes for the 11 Takshashila GCPP modules covered by Policy Wonk." zone="notes">
  <section class="max-w-3xl mx-auto py-8">
    <header class="mb-10">
      <p class="text-xs uppercase tracking-widest text-gray-500 mb-2">Revision</p>
      <h1 class="font-serif text-4xl md:text-5xl font-bold leading-tight">Notes</h1>
      <p class="mt-4 text-gray-700 leading-relaxed text-lg">
        Per-topic revision notes for each Takshashila GCPP module. Notes unlock once you've completed a quiz on that module.
      </p>
      <p class="mt-3 text-sm text-gray-500 leading-relaxed">
        These notes are a blend of public-domain policy concepts, Aasif's own notes,
        and material adapted from the Takshashila GCPP readings. They're a revision aid, not
        a substitute for the original sources.
      </p>
      <div class="mt-6">
        <SearchBar />
      </div>
    </header>

    {groupOrder.map((groupName) => (
      <section class="mb-12">
        <h2 class="font-serif text-2xl font-bold mb-4">{groupName}</h2>
        <ul class="divide-y divide-gray-300">
          {grouped[groupName]?.map((m) => {
            const authored = modulesWithNotes.has(m.id);
            if (!authored) {
              return (
                <li class="py-4 flex items-baseline justify-between gap-4">
                  <p class="font-semibold text-gray-500">{m.code} · {m.name}</p>
                  <span class="text-xs uppercase tracking-widest text-gray-500 whitespace-nowrap">Coming soon</span>
                </li>
              );
            }
            // Default server-render: guest-locked. JS upgrades for logged-in
            // viewers (to "play to unlock") and unlocks (to "browse notes")
            // based on /api/me + /api/me/played-modules.
            return (
              <li
                class="py-4 flex items-baseline justify-between gap-4 module-card"
                data-module-id={m.id}
                data-module-name={m.name}
              >
                <div class="flex-1">
                  <p class="font-semibold text-gray-500 module-title">{m.code} · {m.name}</p>
                  <p class="text-sm text-gray-500 mt-1 module-hint" data-state="guest">
                    Log in to unlock these notes.
                  </p>
                </div>
                <a
                  href="/login"
                  class="text-sm font-medium underline whitespace-nowrap module-cta"
                  data-state="guest"
                >Log in to unlock →</a>
              </li>
            );
          })}
        </ul>
      </section>
    ))}

    <footer class="mt-16 pt-6 border-t border-gray-300 text-sm text-gray-500">
      Notes adapted from Takshashila GCPP course material.
    </footer>
  </section>
</BaseLayout>

<script>
  type MeResponse = {
    ok: boolean;
    user: null | { id: string; nickname: string | null };
  };
  type PlayedResponse = {
    ok: boolean;
    module_ids?: string[];
  };

  (async function upgradeLockState() {
    const cards = document.querySelectorAll<HTMLLIElement>(".module-card");
    if (cards.length === 0) return;

    let me: MeResponse | null = null;
    let played: Set<string> = new Set();

    try {
      const meRes = await fetch("/api/me", { credentials: "same-origin" });
      me = (await meRes.json()) as MeResponse;
    } catch {
      // Network down — leave the default guest state.
      return;
    }
    if (!me?.user) {
      // Truly a guest — default state is correct, nothing to do.
      return;
    }

    try {
      const playedRes = await fetch("/api/me/played-modules", { credentials: "same-origin" });
      const data = (await playedRes.json()) as PlayedResponse;
      played = new Set(data.module_ids ?? []);
    } catch {
      // Could not fetch played list — fall through, all cards stay as
      // "play to unlock" which is still accurate.
    }

    cards.forEach((card) => {
      const moduleId = card.dataset.moduleId!;
      const moduleName = card.dataset.moduleName!;
      const title = card.querySelector<HTMLParagraphElement>(".module-title")!;
      const hint = card.querySelector<HTMLParagraphElement>(".module-hint")!;
      const cta = card.querySelector<HTMLAnchorElement>(".module-cta")!;

      if (played.has(moduleId)) {
        // Unlocked: title becomes the link, hint + cta hidden.
        title.innerHTML = `<a href="/notes/${moduleId}/" class="underline">${title.textContent}</a>`;
        title.classList.remove("text-gray-500");
        title.classList.add("text-black");
        hint.remove();
        cta.remove();
      } else {
        // Logged-in but unplayed.
        hint.textContent = `Play ${moduleName} to unlock these notes.`;
        hint.dataset.state = "unplayed";
        cta.textContent = "Play to unlock →";
        cta.href = "/play";
        cta.dataset.state = "unplayed";
      }
    });
  })();
</script>
