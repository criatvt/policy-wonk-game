---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import modulesData from "../../../data/modules.json";

type Module = (typeof modulesData)[number];

export async function getStaticPaths() {
  const notes = await getCollection("notes");
  const moduleIds = Array.from(new Set(notes.map((n) => n.data.module)));
  return moduleIds.map((id) => ({ params: { module: id } }));
}

const { module } = Astro.params;
const mod = (modulesData as Module[]).find((m) => m.id === module);
if (!mod) {
  throw new Error(`Module not found in modules.json: ${module}`);
}

const allNotes = await getCollection("notes", (n) => n.data.module === module);

// _index entries provide the module-level intro; the rest are topics.
const indexEntry = allNotes.find((n) => n.slug.endsWith("/_index"));
const topics = allNotes
  .filter((n) => n !== indexEntry)
  .sort((a, b) => a.data.order - b.data.order);

// Notes slug is "<module>/<topic-slug>". Topic page URL is /notes/<module>/<topic-slug>/.
function topicSlugOf(noteSlug: string): string {
  const parts = noteSlug.split("/");
  return parts[parts.length - 1];
}
---
<BaseLayout title={`${mod.name} · Notes · Policy Wonk`} description={`Revision notes for ${mod.name}.`} zone="notes">
  <section class="max-w-3xl mx-auto py-8">
    <nav class="mb-8 text-sm">
      <a href="/notes/" class="underline">Notes</a>
      <span class="mx-2 text-gray-400">›</span>
      <span class="text-gray-700">{mod.name}</span>
    </nav>

    <header class="mb-12">
      <p class="text-xs uppercase tracking-widest text-gray-500 mb-2">{mod.code} · {mod.group}</p>
      <h1 class="font-serif text-4xl md:text-5xl font-bold leading-tight">{mod.name}</h1>
      {indexEntry?.data.summary && (
        <p class="mt-4 text-gray-700 leading-relaxed text-lg">{indexEntry.data.summary}</p>
      )}
    </header>

    {topics.length > 0 ? (
      <ul class="divide-y divide-gray-300">
        {topics.map((t) => (
          <li class="py-4">
            <a href={`/notes/${module}/${topicSlugOf(t.slug)}/`} class="block hover:bg-gray-50 -mx-2 px-2 py-1">
              <p class="font-semibold underline">{t.data.title}</p>
              {t.data.summary && <p class="mt-1 text-sm text-gray-700">{t.data.summary}</p>}
            </a>
          </li>
        ))}
      </ul>
    ) : (
      <p class="text-gray-500 italic">Notes for this module are coming soon.</p>
    )}

    <footer class="mt-16 pt-6 border-t border-gray-300 text-sm text-gray-500">
      Adapted from Takshashila GCPP course material.
    </footer>
  </section>
</BaseLayout>
