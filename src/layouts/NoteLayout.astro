---
import BaseLayout from "./BaseLayout.astro";
import SearchBar from "../components/shared/SearchBar.astro";

interface Props {
  title: string;
  module: string;
  moduleName: string;
  summary?: string;
}

const { title, module, moduleName, summary } = Astro.props;
const description = summary ?? `${title} — revision notes from ${moduleName}.`;
---
<BaseLayout title={`${title} · ${moduleName} · Policy Wonk`} description={description} zone="notes">
  <article class="max-w-prose mx-auto py-4">
    <nav class="mb-6 flex flex-wrap items-center justify-between gap-4">
      <div class="text-sm">
        <a href="/notes/" class="underline">Notes</a>
        <span class="mx-2 text-gray-400">›</span>
        <a href={`/notes/${module}/`} class="underline">{moduleName}</a>
      </div>
      <SearchBar />
    </nav>

    <header class="mb-8 pb-6 border-b border-gray-300">
      <p class="text-xs uppercase tracking-widest text-gray-500 mb-2">{moduleName}</p>
      <h1 class="font-serif text-3xl md:text-4xl font-bold leading-tight">{title}</h1>
      {summary && <p class="mt-3 text-gray-700 leading-relaxed text-lg">{summary}</p>}
    </header>

    <div class="prose">
      <slot />
    </div>

    <footer class="mt-16 pt-6 border-t border-gray-300 text-sm text-gray-500 leading-relaxed">
      Revision notes are a blend of public-domain policy concepts, Aasif's own notes,
      and material adapted from the Takshashila GCPP course readings. They're a
      revision aid for the quiz, not a substitute for the original sources.
    </footer>
  </article>
</BaseLayout>
