---
// Site-wide top strip. Slotted by BaseLayout above every page's main
// content. Mirrors the structure on /admin's admin bar (wordmark on the
// left, nav in the middle, auth slot on the right) so the visual logic
// stays consistent between zones.
//
// The auth slot is filled client-side: this is a static site, so we
// fetch /api/me on load and either render the avatar chip + sign-out
// menu (signed in) or a "Sign in" link (guest). Result is cached in
// sessionStorage to avoid the round-trip on every page nav within the
// same tab.
---
<header class="pw-header">
  <a href="/" class="pw-wordmark">Policy Wonk</a>
  <nav class="pw-nav">
    <a href="/notes">Notes</a>
    <a href="/search">Search</a>
  </nav>
  <div class="pw-auth" id="pw-header-auth">
    {/* Filled in by the inline script below. Empty by default so guests
        don't briefly see "Sign in" then have it flip if they're actually
        logged in (or vice versa). */}
  </div>
</header>

<style is:global>
  /* `is:global` is required so the styles apply to DOM the inline script
     injects via innerHTML. Astro's default scoping suffixes rule
     selectors with an `astro-XXXXX` data attribute that script-injected
     nodes don't carry, so without this the chip renders as raw text. */
  .pw-header {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 12px 24px;
    border-bottom: 1px solid var(--color-border, rgba(26, 26, 26, 0.1));
    background: var(--color-bg, #f8f1e4);
    font-family: var(--font-sans, Inter, system-ui, sans-serif);
    font-size: 14px;
  }
  .pw-wordmark {
    font-family: var(--font-serif, "Playfair Display", Georgia, serif);
    font-weight: 700;
    font-size: 18px;
    color: var(--color-charcoal, #1a1a1a);
    text-decoration: none;
    letter-spacing: 0.01em;
  }
  .pw-wordmark:hover { opacity: 0.8; }
  .pw-nav {
    display: flex;
    gap: 8px;
    margin-left: 20px;
  }
  /* Capsule / pill tab styling (2026-05-23): outlined pill so the nav
     reads as a deliberate group instead of plain text links. Outlined
     (not filled) keeps the header airy and visually distinct from the
     filled avatar puck on the right. */
  .pw-nav a {
    color: var(--color-charcoal, #1a1a1a);
    text-decoration: none;
    font-weight: 500;
    padding: 5px 13px;
    border: 1px solid var(--color-border, #e5e5e5);
    border-radius: 999px;
    background: transparent;
    line-height: 1.2;
    transition: background-color 120ms ease, border-color 120ms ease;
  }
  .pw-nav a:hover {
    background: var(--color-bg-soft, #f5f5f5);
    border-color: var(--color-charcoal, #1a1a1a);
  }
  .pw-auth {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 8px;
    position: relative;
  }
  .pw-signin {
    color: var(--color-functional-marigold, #006D77);
    text-decoration: underline;
    text-decoration-thickness: 2px;
    text-underline-offset: 3px;
    font-weight: 600;
  }
  .pw-signin:hover { opacity: 0.85; }
  /* Auth chip (2026-05-23): nickname removed, avatar IS the chip. Solid
     teal disc gives a different visual register from the outlined-pill
     nav tabs to the left — different shape (circle vs pill), different
     colour treatment (filled vs outlined). Teal here reads as a link-
     emphasis surface (the avatar opens the account menu), matching the
     teal accent used elsewhere on the site. */
  .pw-chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    border: 0;
    background: transparent;
    cursor: pointer;
    font: inherit;
    border-radius: 50%;
  }
  .pw-chip:focus-visible {
    outline: 2px solid var(--color-functional-marigold, #006D77);
    outline-offset: 2px;
  }
  .pw-avatar {
    display: inline-flex;
    width: 30px;
    height: 30px;
    align-items: center;
    justify-content: center;
    background: var(--color-functional-marigold, #006D77);
    color: #ffffff;
    border-radius: 50%;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    transition: opacity 120ms ease;
  }
  .pw-chip:hover .pw-avatar { opacity: 0.85; }
  .pw-menu {
    position: absolute;
    top: calc(100% + 6px);
    right: 0;
    min-width: 180px;
    background: var(--color-bg, #f8f1e4);
    border: 1px solid var(--color-border, rgba(26, 26, 26, 0.15));
    border-radius: 6px;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
    padding: 4px;
    z-index: 50;
  }
  .pw-menu[hidden] { display: none; }
  .pw-menu-item {
    display: block;
    width: 100%;
    text-align: left;
    padding: 8px 12px;
    background: transparent;
    border: 0;
    border-radius: 4px;
    cursor: pointer;
    font: inherit;
    color: var(--color-charcoal, #1a1a1a);
  }
  .pw-menu-item:hover { background: rgba(26, 26, 26, 0.06); }
  .pw-menu-nickname {
    padding: 8px 12px 2px;
    font-size: 13px;
    font-weight: 600;
    color: var(--color-charcoal, #1a1a1a);
    word-break: break-word;
  }
  .pw-menu-email {
    padding: 0 12px 8px;
    font-size: 12px;
    color: var(--color-text-muted, #6b6b6b);
    border-bottom: 1px solid var(--color-border, rgba(26, 26, 26, 0.1));
    margin-bottom: 4px;
    word-break: break-all;
  }

  @media (max-width: 540px) {
    .pw-header { padding: 10px 16px; gap: 10px; }
    .pw-nav { gap: 6px; margin-left: 8px; }
    .pw-nav a { padding: 4px 11px; font-size: 13px; }
  }
</style>

<script is:inline>
  (function () {
    const slot = document.getElementById("pw-header-auth");
    if (!slot) return;

    const CACHE_KEY = "pwg:me";
    const CACHE_TTL_MS = 5 * 60 * 1000;

    function renderGuest() {
      // Direct to the email-form view of /login (skips the "two ways in"
      // upsell — header clickers know they want to sign in).
      slot.innerHTML = '<a class="pw-signin" href="/login?show=email">Sign in</a>';
    }

    function renderSignedIn(user) {
      const letter = (user.avatar_slug || user.nickname || user.email || "?").toString().toUpperCase().slice(0, 1);
      const nickname = user.nickname || user.email.split("@")[0];
      const escape = (s) => s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");
      // Avatar-only chip (2026-05-23). Nickname is no longer rendered in
      // the header — it stays inside the dropdown menu for identification.
      // The avatar carries the accessible label so screen readers still
      // know whose account this is.
      slot.innerHTML =
        '<button type="button" class="pw-chip" aria-haspopup="true" aria-expanded="false" aria-label="Account menu for ' + escape(nickname) + '" id="pw-chip-btn">' +
          '<span class="pw-avatar" aria-hidden="true">' + escape(letter) + '</span>' +
        '</button>' +
        '<div class="pw-menu" id="pw-chip-menu" role="menu" hidden>' +
          '<div class="pw-menu-nickname">' + escape(nickname) + '</div>' +
          '<div class="pw-menu-email">' + escape(user.email) + '</div>' +
          '<button type="button" class="pw-menu-item" id="pw-signout-btn" role="menuitem">Sign out</button>' +
        '</div>';

      const btn = document.getElementById("pw-chip-btn");
      const menu = document.getElementById("pw-chip-menu");
      const signOut = document.getElementById("pw-signout-btn");
      if (!btn || !menu || !signOut) return;

      const closeMenu = () => {
        menu.hidden = true;
        btn.setAttribute("aria-expanded", "false");
      };
      btn.addEventListener("click", (e) => {
        e.stopPropagation();
        const open = menu.hidden;
        menu.hidden = !open;
        btn.setAttribute("aria-expanded", open ? "true" : "false");
      });
      document.addEventListener("click", (e) => {
        if (!menu.contains(e.target) && e.target !== btn) closeMenu();
      });
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") closeMenu();
      });
      signOut.addEventListener("click", async () => {
        signOut.disabled = true;
        signOut.textContent = "Signing out…";
        try {
          await fetch("/api/auth/logout", { method: "POST", credentials: "same-origin" });
        } catch {
          // Cookie clear is the source of truth; even if the request fails
          // the user will see a stale chip until they hit a page that
          // actually round-trips. Cheap to ignore for Phase 1.
        }
        try { sessionStorage.removeItem(CACHE_KEY); } catch {}
        window.location.href = "/";
      });
    }

    function applyMe(user) {
      if (user && typeof user === "object") {
        renderSignedIn(user);
      } else {
        renderGuest();
      }
    }

    // Read cached /api/me if it's fresh enough — avoids the round-trip on
    // intra-tab nav. We still re-fetch in the background to catch logout
    // / nickname changes propagating in.
    let usedCache = false;
    try {
      const raw = sessionStorage.getItem(CACHE_KEY);
      if (raw) {
        const parsed = JSON.parse(raw);
        if (parsed && parsed.t && Date.now() - parsed.t < CACHE_TTL_MS) {
          applyMe(parsed.user);
          usedCache = true;
        }
      }
    } catch {}

    fetch("/api/me", { credentials: "same-origin" })
      .then((r) => r.ok ? r.json() : null)
      .then((data) => {
        const user = data && data.user ? data.user : null;
        try { sessionStorage.setItem(CACHE_KEY, JSON.stringify({ t: Date.now(), user })); } catch {}
        applyMe(user);
      })
      .catch(() => {
        if (!usedCache) renderGuest();
      });
  })();
</script>
