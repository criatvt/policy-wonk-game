{
  "name": "policy-wonk-game",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "license": "CC-BY-NC-4.0",
  "description": "Policy Wonk — a 15-question ladder quiz game built on Takshashila GCPP course material.",
  "homepage": "https://policywonkgame.aasifj.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/criatvt/policy-wonk-game.git"
  },
  "scripts": {
    "astro": "astro",
    "build": "node scripts/transform-questions.js && astro build && pagefind --site dist",
    "dev": "node scripts/transform-questions.js && astro dev",
    "notes:clean": "node scripts/clean-and-structure.js",
    "notes:ingest": "node scripts/ingest.js",
    "notes:rebuild": "node scripts/ingest.js --force && node scripts/clean-and-structure.js",
    "preview": "astro preview",
    "start": "npm run dev",
    "transform-questions": "node scripts/transform-questions.js",
    "validate-questions": "node scripts/validate-questions.js"
  },
  "dependencies": {
    "@astrojs/react": "^4.2.0",
    "astro": "^5.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "cheerio": "^1.0.0",
    "fast-xml-parser": "^4.5.0",
    "jszip": "^3.10.1",
    "mammoth": "^1.8.0",
    "pagefind": "^1.3.0",
    "pdf-parse": "^1.1.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0"
  }
}
